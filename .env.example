# Lex Practice OS — environment configuration
# Copy to .env and adjust as needed.

# Port the Express server listens on. Default 4004 for whatsthepayout.com deployment.
PORT=4004

# Path to the SQLite database file. Relative to process.cwd() if not absolute.
# In production, point this at a directory that survives deploys (e.g. a mounted volume).
DATABASE_PATH=./data.db

# NODE_ENV: "development" enables Vite HMR; "production" serves prebuilt assets.
NODE_ENV=production

# Public URL the app is served at (informational only — used for share links, emails, etc.).
PUBLIC_URL=https://whatsthepayout.com
